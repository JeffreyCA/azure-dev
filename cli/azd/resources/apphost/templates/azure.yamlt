{{define "azure.yaml" -}}
# yaml-language-server: $schema=https://raw.githubusercontent.com/azure-javaee/azure-dev/feature/sjad/schemas/alpha/azure.yaml.json
name: {{ .Name }}
{{- if .Services}}
services:
{{- range $name, $value := .Services}}  
  {{$name}}:
    language: dotnet
    project: {{$value}}
    host: containerapp
{{- end}}
{{- end}}
{{ end}}